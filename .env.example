# ─────────────────────────────────────────────
# SUPABASE — client-side (safe to expose to browser)
# Získej z: https://supabase.com/dashboard/project/nebkxqqvbxgbifovrjoe/settings/api
# ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-key

# ─────────────────────────────────────────────
# SUPABASE — server-only (NEVER commit real value)
# ─────────────────────────────────────────────
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────
# PRISMA → Supabase Postgres
# Získej z: Supabase dashboard → Settings → Database → Connection string
# pooler (6543) pro runtime, direct (5432) pro migrace
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ─────────────────────────────────────────────
# RESEND — email pro pozvánky editorů
# Získej z: https://resend.com/api-keys
# ─────────────────────────────────────────────
RESEND_API_KEY=re_your_api_key
EMAIL_FROM="Ostravuj <noreply@your-domain.cz>"

# ─────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────
# ADMIN
# E-mail super-admina. Při prvním přihlášení se mu automaticky
# přiřadí role SUPERADMIN v Profile tabulce.
# ─────────────────────────────────────────────
SUPER_ADMIN_EMAIL=cyril@example.cz
